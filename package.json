{
  "name": "architect-haven",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite dev --open",
    "dev:backend": "convex dev",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "npm run check && convex dev --once && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.80",
    "clsx": "^2.1.1",
    "convex": "^1.31.2",
    "convex-svelte": "^0.0.12",
    "lucide-svelte": "^1.0.1",
    "stripe": "^17.5.0",
    "tailwind-merge": "^3.1.0",
    "three": "^0.183.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^22.13.10",
    "@types/three": "^0.183.0",
    "autoprefixer": "~10",
    "dotenv": "^16.4.7",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "postcss": "~8",
    "prettier": "^3.5.3",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "~3",
    "typescript": "~5.7.2",
    "vite": "^7.1.10",
    "vite-plugin-pwa": "^1.2.0"
  }
}
